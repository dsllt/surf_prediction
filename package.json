    "express-rate-limit": "^8.3.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "module-alias": "^2.3.4",
    "moment": "^2.30.1",
    "mongoose": "^9.2.3",
    "pino": "^10.3.1",
    "swagger-ui-express": "^5.0.1"
  }
